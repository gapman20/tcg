# ===========================================
# TCG Store - Environment Configuration
# ===========================================
# Copy this file to .env and adjust values

# ─── Backend API ──────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001/api

# ─── API Mode ─────────────────────────────────────────────────────────────────
# true = Use real backend API
# false = Use localStorage (demo mode, no backend needed)
VITE_USE_API=true

# ─── PayPal Configuration ─────────────────────────────────────────────────────
# Get your sandbox credentials from https://developer.paypal.com/
# For production, use your live client ID
VITE_PAYPAL_CLIENT_ID=sb

# ─── TCGplayer API (Optional - for price data) ───────────────────────────────
# Get keys from https://api.tcgplayer.com/
# VITE_TCG_PUBLIC_KEY=your_public_key
# VITE_TCG_PRIVATE_KEY=your_private_key
